SERVER_URL=wss://pc-monitor-dashboard.onrender.com?role=agent
AGENT_AUTH_TOKEN=
COMMAND_SIGNING_SECRET=
ALLOW_REMOTE_COMMANDS=false
ALLOW_SCREENSHOT=false
ALLOW_UNLOCK=false
# Пароль Windows для разблокировки экрана (только локально, не коммитить)
UNLOCK_PASSWORD=
# mock = только лог, без действий на ПК; real = реальное выполнение команд
COMMAND_EXECUTION_MODE=real
APPS_CONFIG_PATH=./config/apps.json
